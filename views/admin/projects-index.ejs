<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body style="display:flex;flex-direction:column;min-height:100vh;">
<%- include('../partials/admin-header') %>
<div id="admin-body">
  <div id="admin-sidebar"><%- include('../partials/admin-sidebar', { section }) %></div>
  <div id="admin-main">
    <% if (flash) { %><div class="flash flash-<%= flash.type %>"><%= flash.message %></div><% } %>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
      <div id="breadcrumb" style="flex:1;">Admin <span class="bcsep">&gt;</span> Projects</div>
      <a href="/admin/projects/new" class="btn btn-primary" style="margin-left:8px;">+ New Project</a>
    </div>
    <div class="panel">
      <div class="phead">Projects <span class="mu" style="font-weight:normal;font-size:10px;">(<%= projects.length %> total)</span></div>
      <div class="pbody" style="padding:0;">
        <% if (projects.length === 0) { %>
          <div class="empty">No projects yet. <a href="/admin/projects/new" class="link">Add your first project.</a></div>
        <% } else { %>
          <div class="dtable-wrap">
            <table class="dtable">
              <thead><tr><th>Title</th><th style="width:80px;">Status</th><th style="width:90px;">Updated</th><th style="width:60px;" class="tc">Pub</th><th style="width:60px;" class="tc">Feat.</th><th style="width:120px;">Actions</th></tr></thead>
              <tbody>
                <% projects.forEach(p => { %>
                <tr>
                  <td><a href="/admin/projects/<%= p.id %>/edit" class="link"><%= p.title %></a></td>
                  <td><span class="pstatus pstatus-<%= p.status %>"><%= p.status.toUpperCase() %></span></td>
                  <td class="nw mu" style="font-size:10px;"><%= p.updated_at.substring(0,10).replace(/-/g,'/') %></td>
                  <td class="tc"><span class="<%= p.published ? 's-app':'s-arc' %>"><%= p.published ? 'Yes':'No' %></span></td>
                  <td class="tc" style="color:var(--grey-text);"><%= p.featured ? '&#9733;':'' %></td>
                  <td class="nw">
                    <a href="/admin/projects/<%= p.id %>/edit" class="btn btn-sm">Edit</a>
                    <% if (p.published) { %><a href="/projects/<%= p.slug %>" target="_blank" class="btn btn-sm">View</a><% } %>
                    <form method="POST" action="/admin/projects/<%= p.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this project and all its files?')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm" style="color:var(--red);">Del</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
</body>
</html>
