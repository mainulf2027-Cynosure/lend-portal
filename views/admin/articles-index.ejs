<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body style="display:flex;flex-direction:column;min-height:100vh;">
<%- include('../partials/admin-header') %>
<div id="admin-body">
  <div id="admin-sidebar"><%- include('../partials/admin-sidebar', { section }) %></div>
  <div id="admin-main">
    <% if (flash) { %><div class="flash flash-<%= flash.type %>"><%= flash.message %></div><% } %>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
      <div id="breadcrumb" style="flex:1;">Admin <span class="bcsep">&gt;</span> Articles</div>
      <a href="/admin/articles/new" class="btn btn-primary" style="margin-left:8px;">+ New Article</a>
    </div>
    <div class="panel">
      <div class="phead">Articles <span class="mu" style="font-weight:normal;font-size:10px;">(<%= articles.length %> total)</span></div>
      <div class="pbody" style="padding:0;">
        <% if (articles.length === 0) { %>
          <div class="empty">No articles yet. <a href="/admin/articles/new" class="link">Create your first article.</a></div>
        <% } else { %>
          <div class="dtable-wrap">
            <table class="dtable">
              <thead><tr><th>Title</th><th style="width:90px;">Created</th><th style="width:60px;" class="tc">Status</th><th>Tags</th><th style="width:100px;">Actions</th></tr></thead>
              <tbody>
                <% articles.forEach(a => { %>
                <tr>
                  <td><a href="/admin/articles/<%= a.id %>/edit" class="link"><%= a.title %></a></td>
                  <td class="nw mu" style="font-size:10px;"><%= a.created_at.substring(0,10).replace(/-/g,'/') %></td>
                  <td class="tc"><span class="<%= a.published ? 's-app':'s-arc' %>"><%= a.published ? 'Published':'Draft' %></span></td>
                  <td style="font-size:9px;color:var(--grey-text);"><%= a.tags || '—' %></td>
                  <td class="nw">
                    <a href="/admin/articles/<%= a.id %>/edit" class="btn btn-sm">Edit</a>
                    <% if (a.published) { %><a href="/articles/<%= a.slug %>" target="_blank" class="btn btn-sm">View</a><% } %>
                    <form method="POST" action="/admin/articles/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this article?')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm" style="color:var(--red);">Del</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
</body>
</html>
