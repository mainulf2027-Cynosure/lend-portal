<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body style="display:flex;flex-direction:column;min-height:100vh;">
<%- include('../partials/admin-header') %>
<div id="admin-body">
  <div id="admin-sidebar"><%- include('../partials/admin-sidebar', { section }) %></div>
  <div id="admin-main">
    <% if (flash) { %><div class="flash flash-<%= flash.type %>"><%= flash.message %></div><% } %>
    <div id="breadcrumb" style="margin-bottom:6px;">Admin <span class="bcsep">&gt;</span> <a href="/admin/videos" class="link">Videos</a> <span class="bcsep">&gt;</span> <%= video ? 'Edit' : 'New' %></div>

    <form method="POST" action="<%= video ? '/admin/videos/'+video.id+'/edit' : '/admin/videos/new' %>" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="display:flex;gap:6px;align-items:flex-start;">

        <div style="flex:1;min-width:0;">
          <div class="panel">
            <div class="phead">Video Details</div>
            <div class="pbody" style="padding:8px;">
              <div class="ff">
                <label>Title *</label>
                <input type="text" name="title" value="<%= video ? video.title : '' %>" required maxlength="300" style="max-width:100%;">
              </div>
              <div class="ff">
                <label>Description</label>
                <textarea name="description" rows="3"><%= video ? video.description || '' : '' %></textarea>
              </div>
              <div class="panel" style="margin-bottom:8px;">
                <div class="phead">Option A — Embed URL</div>
                <div class="pbody" style="padding:6px;">
                  <div class="ff" style="margin:0;">
                    <label>YouTube / Vimeo Embed URL <span class="ff-hint">(e.g. https://www.youtube.com/embed/VIDEO_ID)</span></label>
                    <input type="url" name="embed_url" value="<%= video ? video.embed_url || '' : '' %>" placeholder="https://www.youtube.com/embed/..." style="max-width:100%;">
                  </div>
                </div>
              </div>
              <div class="panel">
                <div class="phead">Option B — Upload Video File</div>
                <div class="pbody" style="padding:6px;">
                  <% if (video && video.filename) { %>
                    <div style="font-size:10px;color:var(--grey-text);margin-bottom:4px;">Current file: <code><%= video.filename %></code></div>
                  <% } %>
                  <input type="file" name="video_file" accept="video/*" style="font-size:11px;">
                  <div class="ff-hint" style="margin-top:3px;">Supported: MP4, WebM, OGG. Max 2 GB.</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div style="width:180px;flex-shrink:0;">
          <div class="panel">
            <div class="phead">Publish</div>
            <div class="pbody" style="padding:8px;">
              <label class="ff-check"><input type="checkbox" name="published" value="1" <%= video && video.published ? 'checked':'' %>> Published</label>
              <div style="margin-top:8px;display:flex;flex-direction:column;gap:3px;">
                <button type="submit" class="btn btn-primary" style="width:100%;">Save</button>
                <a href="/admin/videos" class="btn" style="width:100%;text-align:center;display:block;text-decoration:none;">Cancel</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </form>
  </div>
</div>
<%- include('../partials/admin-footer') %>
</body>
</html>
