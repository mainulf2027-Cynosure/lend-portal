<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body style="display:flex;flex-direction:column;min-height:100vh;">
<%- include('../partials/admin-header') %>
<div id="admin-body">
  <div id="admin-sidebar"><%- include('../partials/admin-sidebar', { section }) %></div>
  <div id="admin-main">
    <% if (flash) { %><div class="flash flash-<%= flash.type %>"><%= flash.message %></div><% } %>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
      <div id="breadcrumb" style="flex:1;">Admin <span class="bcsep">&gt;</span> Notes</div>
      <a href="/admin/notes/new" class="btn btn-primary" style="margin-left:8px;">+ New Note</a>
    </div>
    <div class="panel">
      <div class="phead">Notes <span class="mu" style="font-weight:normal;font-size:10px;">(<%= notes.length %> total)</span></div>
      <div class="pbody" style="padding:0;">
        <% if (notes.length === 0) { %>
          <div class="empty">No notes yet. <a href="/admin/notes/new" class="link">Create your first note.</a></div>
        <% } else { %>
          <div class="dtable-wrap">
            <table class="dtable">
              <thead><tr><th>Title</th><th style="width:90px;">Updated</th><th style="width:60px;" class="tc">Public</th><th>Tags</th><th style="width:100px;">Actions</th></tr></thead>
              <tbody>
                <% notes.forEach(n => { %>
                <tr>
                  <td><a href="/admin/notes/<%= n.id %>/edit" class="link"><%= n.title %></a></td>
                  <td class="nw mu" style="font-size:10px;"><%= n.updated_at.substring(0,10).replace(/-/g,'/') %></td>
                  <td class="tc"><span class="<%= n.public ? 's-app':'s-arc' %>"><%= n.public ? 'Yes':'No' %></span></td>
                  <td style="font-size:9px;color:var(--grey-text);"><%= n.tags || '—' %></td>
                  <td class="nw">
                    <a href="/admin/notes/<%= n.id %>/edit" class="btn btn-sm">Edit</a>
                    <% if (n.public) { %><a href="/notes/<%= n.slug %>" target="_blank" class="btn btn-sm">View</a><% } %>
                    <form method="POST" action="/admin/notes/<%= n.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this note?')">
                      <button type="submit" class="btn btn-sm" style="color:var(--red);">Del</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
</body>
</html>
