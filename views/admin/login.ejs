<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/colors_and_type.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/site.css">
</head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:var(--win-bg);">
  <div style="width:320px;">
    <div style="text-align:center;margin-bottom:10px;">
      <img src="/assets/lend-logo.svg" alt="LEND" style="width:180px;">
      <div style="font-size:10px;color:var(--grey-text);margin-top:4px;">Content Management System</div>
    </div>
    <div class="panel">
      <div class="phead">Administrator Login</div>
      <div class="pbody" style="padding:12px;">
        <% if (flash) { %><div class="flash flash-<%= flash.type %>" style="margin-bottom:8px;"><%= flash.message %></div><% } %>
        <form method="POST" action="/admin/login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="ff">
            <label>Username:</label>
            <input type="text" name="username" autofocus required style="max-width:100%;">
          </div>
          <div class="ff">
            <label>Password:</label>
            <input type="password" name="password" required style="max-width:100%;">
          </div>
          <div style="margin-top:10px;">
            <button type="submit" class="btn btn-primary" style="width:100%;">Log In</button>
          </div>
        </form>
      </div>
    </div>
    <div style="text-align:center;margin-top:8px;font-size:9px;color:var(--grey-text);">
      LEND CMS v1.0 &nbsp;|&nbsp; Mainul Fahad
    </div>
  </div>
</body>
</html>
