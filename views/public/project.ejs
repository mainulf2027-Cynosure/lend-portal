<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body>
<%- include('../partials/public-header', { activePage }) %>
<div id="page-shell">
<div id="breadcrumb"><a href="/">Home</a><span class="bcsep">&gt;</span><a href="/projects">Projects</a><span class="bcsep">&gt;</span><%= project.title %></div>
<div id="main">

  <div style="display:flex;gap:6px;align-items:flex-start;">

    <!-- Main content -->
    <div style="flex:1;min-width:0;">
      <div class="panel" style="margin-bottom:6px;">
        <div class="phead" style="display:flex;justify-content:space-between;align-items:center;">
          <span style="font-weight:bold;font-size:12px;"><%= project.title %></span>
          <span class="pstatus pstatus-<%= project.status %>"><%= project.status.toUpperCase() %></span>
        </div>
        <div class="pbody" style="padding:10px 12px;">
          <% if (project.description) { %>
            <div style="font-size:11px;color:#333;margin-bottom:8px;border-bottom:1px solid var(--border);padding-bottom:6px;"><%= project.description %></div>
          <% } %>
          <% if (project.technologies) { %>
            <div style="margin-bottom:8px;"><span style="font-size:10px;font-weight:bold;color:var(--crimson-text);">Technologies:</span> <% project.technologies.split(',').forEach(t => { %><span class="tag"><%= t.trim() %></span><% }) %></div>
          <% } %>
          <div class="rc"><%- content %></div>
        </div>
      </div>
    </div>

    <!-- Sidebar: links + downloads -->
    <div style="width:220px;flex-shrink:0;">
      <div class="panel" style="margin-bottom:6px;">
        <div class="phead">Project Info</div>
        <div class="pbody">
          <table style="width:100%;font-size:10px;border-collapse:collapse;">
            <tr><td style="color:var(--grey-text);padding:2px 0;">Status:</td><td style="font-weight:bold;padding:2px 4px;"><%= project.status %></td></tr>
            <tr><td style="color:var(--grey-text);padding:2px 0;">Updated:</td><td style="padding:2px 4px;"><%= project.updated_at.substring(0,10).replace(/-/g,'/') %></td></tr>
          </table>
          <% if (project.repo_url) { %><div style="margin-top:5px;"><a href="<%= project.repo_url %>" target="_blank" class="btn btn-sm" style="width:100%;text-align:center;display:block;">Repository</a></div><% } %>
          <% if (project.demo_url) { %><div style="margin-top:3px;"><a href="<%= project.demo_url %>" target="_blank" class="btn btn-primary btn-sm" style="width:100%;text-align:center;display:block;">Live Demo</a></div><% } %>
        </div>
      </div>

      <% if (files.length > 0) { %>
      <div class="panel">
        <div class="phead">Downloads</div>
        <div class="pbody" style="padding:4px 6px;">
          <ul class="dl-list">
            <% files.forEach(f => { %>
            <li class="dl-item">
              <span class="ico ico-file"></span>
              <div style="flex:1;min-width:0;">
                <a href="/projects/<%= project.slug %>/download/<%= f.id %>" class="link" style="font-size:11px;"><%= f.original_name %></a>
                <% if (f.description) { %><div style="font-size:9px;color:var(--grey-text);"><%= f.description %></div><% } %>
              </div>
              <span class="dl-size"><%= formatBytes(f.size) %></span>
            </li>
            <% }) %>
          </ul>
        </div>
      </div>
      <% } %>
    </div>

  </div>

  <div style="margin-top:4px;"><a href="/projects" class="btn">&laquo; Back to Projects</a></div>
</div>
<%- include('../partials/public-footer') %>
</div>
</body>
</html>
