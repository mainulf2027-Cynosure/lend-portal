<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body>
<%- include('../partials/public-header', { activePage }) %>
<div id="page-shell">
<div id="breadcrumb"><a href="/">Home</a><span class="bcsep">&gt;</span><a href="/notes">Notes</a><span class="bcsep">&gt;</span><%= note.title %></div>
<div id="main">
  <div class="panel">
    <div class="phead">
      <%= note.title %>
      <span class="ph-link mu" style="font-weight:normal;"><%= note.updated_at.substring(0,10).replace(/-/g,'/') %></span>
    </div>
    <div class="pbody" style="padding:10px 12px;">
      <% if (note.tags) { %><div style="margin-bottom:8px;"><% note.tags.split(',').forEach(t => { %><span class="tag"><%= t.trim() %></span><% }) %></div><% } %>
      <div class="rc"><%- content %></div>
    </div>
  </div>
  <div style="margin-top:6px;"><a href="/notes" class="btn">&laquo; Back to Notes</a></div>
</div>
<%- include('../partials/public-footer') %>
</div>
</body>
</html>
