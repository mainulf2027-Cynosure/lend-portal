<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body>
<%- include('../partials/public-header', { activePage }) %>
<div id="page-shell">
<div id="breadcrumb"><a href="/">Home</a><span class="bcsep">&gt;</span>Videos</div>
<div id="main">
  <% if (videos.length === 0) { %>
    <div class="panel">
      <div class="phead">Videos</div>
      <div class="pbody"><div class="empty">No videos published yet.</div></div>
    </div>
  <% } else { %>
    <div class="vid-grid">
      <% videos.forEach(v => { %>
      <div class="panel">
        <div class="phead"><%= v.title %></div>
        <div class="pbody" style="padding:6px;">
          <% if (v.embed_url) { %>
            <iframe class="vid-embed" src="<%= v.embed_url %>" allowfullscreen frameborder="0"></iframe>
          <% } else if (v.filename) { %>
            <video class="vid-local" controls>
              <source src="/uploads/videos/<%= v.filename %>">
              Your browser does not support the video element.
            </video>
          <% } else { %>
            <div style="font-size:10px;color:var(--grey-text);padding:10px;">No video source available.</div>
          <% } %>
          <% if (v.description) { %>
            <div style="margin-top:5px;font-size:11px;color:#333;"><%= v.description %></div>
          <% } %>
          <div style="margin-top:4px;font-size:9px;color:var(--grey-text);"><%= v.created_at.substring(0,10).replace(/-/g,'/') %></div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/public-footer') %>
</div>
</body>
</html>
