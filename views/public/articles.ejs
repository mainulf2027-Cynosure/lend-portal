<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body>
<%- include('../partials/public-header', { activePage }) %>
<div id="page-shell">
<div id="breadcrumb"><a href="/">Home</a><span class="bcsep">&gt;</span>Articles</div>
<div id="main">
  <div class="panel">
    <div class="phead">
      Articles
      <span class="ph-link mu"><%= total %> article<%= total !== 1 ? 's' : '' %> total</span>
    </div>
    <div class="pbody" style="padding:0;">
      <% if (articles.length === 0) { %>
        <div class="empty">No articles published yet.</div>
      <% } else { %>
        <div class="dtable-wrap">
          <table class="dtable">
            <thead>
              <tr><th>Title</th><th style="width:90px;">Date</th><th>Tags</th></tr>
            </thead>
            <tbody>
              <% articles.forEach(a => { %>
              <tr>
                <td>
                  <a href="/articles/<%= a.slug %>" class="link"><%= a.title %></a>
                  <% if (a.excerpt) { %><div style="font-size:10px;color:var(--grey-text);margin-top:1px;"><%= a.excerpt.substring(0,100) %><%= a.excerpt.length > 100 ? '...' : '' %></div><% } %>
                </td>
                <td class="nw mu" style="font-size:10px;"><%= a.created_at.substring(0,10).replace(/-/g,'/') %></td>
                <td style="font-size:10px;"><%= a.tags || '' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% if (totalPages > 1) { %>
        <div class="pager">
          <% if (currentPage > 1) { %><a href="/articles?page=<%= currentPage-1 %>" class="pg-btn">&laquo; Prev</a><% } %>
          <% for(let i=1;i<=totalPages;i++) { %><a href="/articles?page=<%= i %>" class="pg-btn <%= i===currentPage?'cur':'' %>"><%= i %></a><% } %>
          <% if (currentPage < totalPages) { %><a href="/articles?page=<%= currentPage+1 %>" class="pg-btn">Next &raquo;</a><% } %>
        </div>
        <% } %>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/public-footer') %>
</div>
</body>
</html>
