<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title }) %>
<body>
<%- include('../partials/public-header', { activePage }) %>
<div id="page-shell">
<div id="breadcrumb"><a href="/">Home</a><span class="bcsep">&gt;</span>Contact</div>
<div id="main">
  <% if (flash) { %><div class="flash flash-<%= flash.type %>" style="max-width:640px;"><%= flash.message %></div><% } %>

  <div class="panel contact-wrap">
    <div class="phead">Contact — Mainul Fahad</div>
    <div class="pbody" style="padding:10px 12px;">

      <div style="font-size:11px;color:#444;margin-bottom:10px;border-bottom:1px solid var(--border);padding-bottom:8px;">
        Send a message. All fields marked with an asterisk (*) are required.
      </div>

      <form method="POST" action="/contact" style="max-width:560px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="ff">
          <label>Name *</label>
          <input type="text" name="name" required maxlength="120" placeholder="Your name">
        </div>
        <div class="ff">
          <label>Email Address *</label>
          <input type="email" name="email" required maxlength="200" placeholder="your@email.com">
        </div>
        <div class="ff">
          <label>Subject</label>
          <input type="text" name="subject" maxlength="200" placeholder="Subject (optional)">
        </div>
        <div class="ff">
          <label>Message *</label>
          <textarea name="message" rows="8" required maxlength="5000" placeholder="Your message..."></textarea>
        </div>
        <div class="form-actions" style="border-top:none;margin-top:6px;">
          <button type="submit" class="btn btn-primary">Send Message</button>
          <button type="reset" class="btn">Clear</button>
        </div>
      </form>

    </div>
  </div>
</div>
<%- include('../partials/public-footer') %>
</div>
</body>
</html>
